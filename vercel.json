{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "astro",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "cleanUrls": false,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" },
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; base-uri 'self'; object-src 'none'; frame-ancestors 'self'; form-action 'self' https://wa.me mailto:; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://cdn.tailwindcss.com https://cdn.jsdelivr.net https://esm.sh https://unpkg.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com data:; img-src 'self' data: blob: https:; connect-src 'self' https://*.supabase.co wss://*.supabase.co https://api.microlink.io; manifest-src 'self'; worker-src 'self'; upgrade-insecure-requests"
        }
      ]
    },
    {
      "source": "/sw.js",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" },
        { "key": "Service-Worker-Allowed", "value": "/" }
      ]
    },
    {
      "source": "/manifest.webmanifest",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=3600, stale-while-revalidate=86400" },
        { "key": "Content-Type", "value": "application/manifest+json; charset=utf-8" }
      ]
    },
    {
      "source": "/(.*)\\.html",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    },
    {
      "source": "/",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    },
    {
      "source": "/espace-etudiant/:path*",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    },
    {
      "source": "/jobs-etudiants.html",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    },
    {
      "source": "/offres-etudiants.html",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    },
    {
      "source": "/assets/js/vendor/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/assets/js/student-jobs.mjs",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    },
    {
      "source": "/assets/js/sa-supabase-loader.mjs",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    },
    {
      "source": "/assets/js/espace-etudiant.mjs",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    },
    {
      "source": "/assets/js/espace-dashboard.mjs",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    },
    {
      "source": "/assets/js/user-site-context.mjs",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    },
    {
      "source": "/assets/js/config.js",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    },
    {
      "source": "/assets/js/header.js",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    },
    {
      "source": "/assets/js/main.js",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    },
    {
      "source": "/assets/js/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=300, s-maxage=300, stale-while-revalidate=86400"
        }
      ]
    },
    {
      "source": "/assets/css/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=3600, stale-while-revalidate=86400" }
      ]
    },
    {
      "source": "/assets/img/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=2592000, immutable" }
      ]
    },
    {
      "source": "/assets/social/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=2592000, immutable" }
      ]
    },
    {
      "source": "/assets/docs/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=86400, stale-while-revalidate=604800" }
      ]
    },
    {
      "source": "/assets/data/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=300, s-maxage=300, stale-while-revalidate=86400" }
      ]
    }
  ],
  "redirects": [
    { "source": "/index.html", "destination": "/", "permanent": true },
    { "source": "/accelerateur-job.html", "destination": "/accelerateur-job", "permanent": true },
    { "source": "/admin.html", "destination": "/admin", "permanent": true },
    { "source": "/admin-login.html", "destination": "/admin-login", "permanent": true },
    { "source": "/analyseur-admission.html", "destination": "/analyseur-admission", "permanent": true },
    { "source": "/annuaire.html", "destination": "/annuaire", "permanent": true },
    { "source": "/assurance-visa.html", "destination": "/assurance-visa", "permanent": true },
    { "source": "/besoin-d-aide.html", "destination": "/besoin-d-aide", "permanent": true },
    { "source": "/communaute.html", "destination": "/communaute", "permanent": true },
    { "source": "/compte-bloque.html", "destination": "/compte-bloque", "permanent": true },
    { "source": "/conditions-generales.html", "destination": "/conditions-generales", "permanent": true },
    { "source": "/creer-evenement.html", "destination": "/creer-evenement", "permanent": true },
    { "source": "/creer-profil.html", "destination": "/creer-profil", "permanent": true },
    { "source": "/dashboard.html", "destination": "/dashboard", "permanent": true },
    { "source": "/devenir-professionnel.html", "destination": "/devenir-professionnel", "permanent": true },
    { "source": "/engagement-ethique.html", "destination": "/engagement-ethique", "permanent": true },
    { "source": "/equivalence.html", "destination": "/equivalence", "permanent": true },
    { "source": "/espace-etudiant/dashboard.html", "destination": "/espace-etudiant/dashboard", "permanent": true },
    { "source": "/evenements-seminaires.html", "destination": "/evenements-seminaires", "permanent": true },
    { "source": "/inscription-universitaire.html", "destination": "/inscription-universitaire", "permanent": true },
    { "source": "/jobs-etudiants.html", "destination": "/offres-etudiants", "permanent": true },
    { "source": "/liste-etablissements-enseignement-belgique.html", "destination": "/liste-etablissements-enseignement-belgique", "permanent": true },
    { "source": "/logement-etudiant.html", "destination": "/logement-etudiant", "permanent": true },
    { "source": "/mentions-legales.html", "destination": "/mentions-legales", "permanent": true },
    { "source": "/mise-en-relation.html", "destination": "/mise-en-relation", "permanent": true },
    { "source": "/notre-dossier-fwb.html", "destination": "/notre-dossier-fwb", "permanent": true },
    { "source": "/offres-etudiants.html", "destination": "/offres-etudiants", "permanent": true },
    { "source": "/pack-accueil.html", "destination": "/pack-accueil", "permanent": true },
    { "source": "/politique-confidentialite.html", "destination": "/politique-confidentialite", "permanent": true },
    { "source": "/politique-cookies.html", "destination": "/politique-cookies", "permanent": true },
    { "source": "/positionnement-etudiants-belgique.html", "destination": "/positionnement-etudiants-belgique", "permanent": true },
    { "source": "/preparer-voyage.html", "destination": "/preparer-voyage", "permanent": true },
    { "source": "/prequalification-dossier.html", "destination": "/prequalification-dossier", "permanent": true },
    { "source": "/qui-sommes-nous.html", "destination": "/qui-sommes-nous", "permanent": true },
    { "source": "/rejoindre-reseau.html", "destination": "/rejoindre-reseau", "permanent": true },
    { "source": "/services-bancaires.html", "destination": "/services-bancaires", "permanent": true },
    { "source": "/tarifs-packs.html", "destination": "/tarifs-packs", "permanent": true },
    { "source": "/blog/bac-13-moyenne-etudier-belgique.html", "destination": "/blog/bac-13-moyenne-etudier-belgique", "permanent": true },
    { "source": "/blog/belgique-etudes-job-actualites.html", "destination": "/blog/belgique-etudes-job-actualites", "permanent": true },
    { "source": "/blog/campus-belgique-cameroun-visa-impact.html", "destination": "/blog/campus-belgique-cameroun-visa-impact", "permanent": true },
    { "source": "/blog/equivalence-bts-cameroun-belgique.html", "destination": "/blog/equivalence-bts-cameroun-belgique", "permanent": true },
    { "source": "/blog/gce-a-level-etudes-fwb.html", "destination": "/blog/gce-a-level-etudes-fwb", "permanent": true },
    { "source": "/blog/ku-leuven-bourse-afrique.html", "destination": "/blog/ku-leuven-bourse-afrique", "permanent": true },
    { "source": "/blog/recuperer-originaux-equivalence-fwb.html", "destination": "/blog/recuperer-originaux-equivalence-fwb", "permanent": true },
    {
      "source": "/communaute/rejoindre",
      "destination": "/rejoindre-reseau?vue=communaute",
      "permanent": false
    },
    {
      "source": "/communaute/inscription",
      "destination": "/espace-etudiant/?vue=communaute&tab=inscription",
      "permanent": false
    },
    { "source": "/jobs-etudiants", "destination": "/offres-etudiants", "permanent": false },
    { "source": "/bourses", "destination": "/blog#bourses", "permanent": false },
    { "source": "/contact", "destination": "/#contact", "permanent": false },
    { "source": "/equivalence-fwb", "destination": "/equivalence", "permanent": true },
    {
      "source": "/auth/callback",
      "destination": "/espace-etudiant/",
      "permanent": false
    },
    {
      "source": "/auth/v1/callback",
      "destination": "/espace-etudiant/",
      "permanent": false
    }
  ]
}
