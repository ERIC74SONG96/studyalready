{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "cleanUrls": true,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=2592000, immutable" }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "studyalready.com" }],
      "destination": "https://www.studyalready.com/:path*",
      "permanent": true
    },
    {
      "source": "/communaute/inscription",
      "destination": "/espace-etudiant/?vue=communaute&tab=inscription",
      "permanent": false
    },
    { "source": "/contact", "destination": "/#contact", "permanent": false },
    { "source": "/equivalence-fwb", "destination": "/equivalence", "permanent": true },
    {
      "source": "/auth/callback",
      "destination": "/espace-etudiant/",
      "permanent": false
    },
    {
      "source": "/auth/v1/callback",
      "destination": "/espace-etudiant/",
      "permanent": false
    }
  ]
}
