{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "cleanUrls": false,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" }
      ]
    },
    {
      "source": "/espace-etudiant/:path*",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    },
    {
      "source": "/jobs-etudiants.html",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    },
    {
      "source": "/offres-etudiants.html",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    },
    {
      "source": "/assets/js/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=300, s-maxage=300, stale-while-revalidate=86400"
        }
      ]
    },
    {
      "source": "/assets/css/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=3600, stale-while-revalidate=86400" }
      ]
    },
    {
      "source": "/assets/img/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=2592000, immutable" }
      ]
    },
    {
      "source": "/assets/social/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=2592000, immutable" }
      ]
    },
    {
      "source": "/assets/docs/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=86400, stale-while-revalidate=604800" }
      ]
    },
    {
      "source": "/assets/data/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=300, s-maxage=300, stale-while-revalidate=86400" }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "studyalready.com" }],
      "destination": "https://www.studyalready.com/:path*",
      "permanent": true
    },
    {
      "source": "/blog/equivalence-bts-cameroun-belgique",
      "destination": "/blog/equivalence-bts-cameroun-belgique.html",
      "permanent": true
    },
    {
      "source": "/blog/gce-a-level-etudes-fwb",
      "destination": "/blog/gce-a-level-etudes-fwb.html",
      "permanent": true
    },
    {
      "source": "/blog/recuperer-originaux-equivalence-fwb",
      "destination": "/blog/recuperer-originaux-equivalence-fwb.html",
      "permanent": true
    },
    {
      "source": "/blog/belgique-etudes-job-actualites",
      "destination": "/blog/belgique-etudes-job-actualites.html",
      "permanent": true
    },
    {
      "source": "/communaute/rejoindre",
      "destination": "/rejoindre-reseau.html?vue=communaute",
      "permanent": false
    },
    {
      "source": "/communaute/inscription",
      "destination": "/espace-etudiant/?vue=communaute&tab=inscription",
      "permanent": false
    },
    { "source": "/jobs-etudiants", "destination": "/offres-etudiants.html", "permanent": false },
    { "source": "/contact", "destination": "/#contact", "permanent": false },
    { "source": "/equivalence-fwb", "destination": "/equivalence", "permanent": true },
    {
      "source": "/auth/callback",
      "destination": "/espace-etudiant/",
      "permanent": false
    },
    {
      "source": "/auth/v1/callback",
      "destination": "/espace-etudiant/",
      "permanent": false
    }
  ]
}
