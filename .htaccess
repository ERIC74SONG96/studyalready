# StudyAlready - Configuration Apache pour LWS
# Sécurité, performance et bonnes pratiques

# ============== ENCODAGE ==============
AddDefaultCharset UTF-8
AddType application/manifest+json .webmanifest

# ============== FORCER HTTPS (à activer après installation du certificat SSL) ==============
# RewriteEngine On
# RewriteCond %{HTTPS} off
# RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# ============== REDIRIGER WWW VERS NON-WWW (au choix) ==============
# RewriteCond %{HTTP_HOST} ^www\.(.+)$ [NC]
# RewriteRule ^ https://%1%{REQUEST_URI} [R=301,L]

# URLs propres : dossiers /page/index.html (pas de mod_rewrite requis).
# Les fichiers page.html restent la référence ; régénérer avec scripts/generate-url-folders.py
DirectoryIndex index.html index.htm

# ============== EN-TÊTES DE SÉCURITÉ ==============
<IfModule mod_headers.c>
    Header set X-Content-Type-Options "nosniff"
    Header set X-Frame-Options "SAMEORIGIN"
    Header set Referrer-Policy "strict-origin-when-cross-origin"
    Header set Permissions-Policy "camera=(), microphone=(), geolocation=()"
    Header set Content-Security-Policy "default-src 'self'; base-uri 'self'; object-src 'none'; frame-ancestors 'self'; form-action 'self' https://wa.me mailto:; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://cdn.tailwindcss.com https://cdn.jsdelivr.net https://esm.sh https://unpkg.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com data:; img-src 'self' data: blob: https:; connect-src 'self' https://*.supabase.co wss://*.supabase.co https://api.microlink.io; manifest-src 'self'; worker-src 'self'; upgrade-insecure-requests"
</IfModule>

<Files "sw.js">
    <IfModule mod_headers.c>
        Header set Cache-Control "public, max-age=0, must-revalidate"
        Header set Service-Worker-Allowed "/"
    </IfModule>
</Files>

# ============== CACHE NAVIGATEUR (performance) ==============
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType text/css                 "access plus 1 month"
    ExpiresByType application/javascript   "access plus 1 month"
    ExpiresByType image/jpeg               "access plus 6 months"
    ExpiresByType image/png                "access plus 6 months"
    ExpiresByType image/svg+xml            "access plus 6 months"
    ExpiresByType image/webp               "access plus 6 months"
    ExpiresByType font/woff2               "access plus 1 year"
    ExpiresByType text/html                "access plus 1 hour"
</IfModule>

# ============== COMPRESSION GZIP ==============
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/css text/javascript application/javascript application/json image/svg+xml
</IfModule>

# ============== INTERDIRE L'ACCÈS AUX FICHIERS SENSIBLES ==============
<FilesMatch "^\.(htaccess|env|git)">
    Require all denied
</FilesMatch>

# ============== PAGE D'ERREUR PERSONNALISÉE ==============
ErrorDocument 404 /404.html
